# Use Node.js 18 on Alpine Linux (Lightweight)
FROM node:18-alpine

# Set working directory inside the container
WORKDIR /app

# 1. Install dependencies
# Copy package.json and package-lock.json (if available)
COPY package*.json ./
RUN npm install

# 2. Copy the rest of the application code
COPY . .

ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME
ARG NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET
ARG NEXT_PUBLIC_FINRAG_MCP_API_URL

# 2. Set them as environment variables so Next.js build can see them
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=$NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME
ENV NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=$NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET
ENV NEXT_PUBLIC_FINRAG_MCP_API_URL=$NEXT_PUBLIC_FINRAG_MCP_API_URL

# 3. Build the Next.js application
RUN npm run build

# 4. Expose the port Next.js runs on
EXPOSE 3000

# 5. Start the application
CMD ["npm", "start"]